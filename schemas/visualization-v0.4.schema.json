{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://explainer.local/schemas/visualization-v0.4.schema.json",
  "title": "Visualization Language v0.4",
  "type": "object",
  "required": ["schema_version", "id", "title", "entry", "root_board", "boards"],
  "properties": {
    "schema_version": { "const": "visualization-v0.4" },
    "id": { "$ref": "#/$defs/id" },
    "title": { "$ref": "#/$defs/nonEmptyString" },
    "entry": {
      "type": "object",
      "required": ["architecture"],
      "properties": {
        "architecture": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "root_board": { "$ref": "#/$defs/id" },
    "boards": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/board" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "notationString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*_\\().+$"
    },
    "representationGlyph": {
      "enum": ["scalar", "vector", "single", "matrix", "pair", "volume", "dictionary", "coordinates", "frames"]
    },
    "nodeRef": { "type": "string", "pattern": "^(modules|value_sites)\\.[a-z][a-z0-9_]*$" },
    "moduleRef": { "type": "string", "pattern": "^modules\\.[a-z][a-z0-9_]*$" },
    "representationRef": { "type": "string", "pattern": "^representations\\.[a-z][a-z0-9_]*$" },
    "relationRef": { "type": "string", "pattern": "^relations\\.[a-z][a-z0-9_]*$" },
    "executionLoopRef": { "type": "string", "pattern": "^execution\\.loops\\.[a-z][a-z0-9_]*$" },
    "board": {
      "type": "object",
      "required": ["id", "title", "summary", "subject_ref", "expansion_depth"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "const": "standard_block_instance" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "parent": { "$ref": "#/$defs/id" },
        "subject_ref": {
          "oneOf": [
            { "const": "architecture" },
            { "$ref": "#/$defs/moduleRef" }
          ]
        },
        "expansion_depth": { "type": "integer", "minimum": 0 },
        "grid": { "$ref": "#/$defs/grid" },
        "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
        "nodes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } },
        "regions": { "type": "array", "items": { "$ref": "#/$defs/region" } },
        "occurrence_bindings": { "type": "array", "items": { "$ref": "#/$defs/occurrenceBinding" } },
        "elide": { "type": "array", "items": { "$ref": "#/$defs/elide" } },
        "exclude": { "type": "array", "items": { "$ref": "#/$defs/exclude" } },
        "edge_overrides": { "type": "array", "items": { "$ref": "#/$defs/edgeOverride" } },
        "reference_panels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/referencePanel" }
        },
        "notes": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } }
        ,
        "block_instance_ref": {
          "type": "string",
          "pattern": "^block_instances\\.[a-z][a-z0-9_]*$"
        }
      },
      "additionalProperties": false
    },
    "referencePanel": {
      "type": "object",
      "required": [
        "id",
        "title",
        "asset",
        "alt",
        "caption",
        "source_ref",
        "locator",
        "license_note",
        "position"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "asset": {
          "type": "string",
          "pattern": "^assets/reference-panels/[a-z0-9][a-z0-9_/-]*\\.(png|jpg|jpeg|webp)$"
        },
        "alt": { "$ref": "#/$defs/nonEmptyString" },
        "caption": { "$ref": "#/$defs/nonEmptyString" },
        "source_ref": { "$ref": "#/$defs/id" },
        "locator": { "$ref": "#/$defs/nonEmptyString" },
        "license_note": { "$ref": "#/$defs/nonEmptyString" },
        "position": { "enum": ["right"] }
      },
      "additionalProperties": false
    },
    "standardBlockInstanceBoard": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "title",
        "summary",
        "parent",
        "subject_ref",
        "expansion_depth",
        "block_instance_ref"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "const": "standard_block_instance" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "parent": { "$ref": "#/$defs/id" },
        "subject_ref": { "$ref": "#/$defs/moduleRef" },
        "expansion_depth": { "type": "integer", "minimum": 0 },
        "block_instance_ref": {
          "type": "string",
          "pattern": "^block_instances\\.[a-z][a-z0-9_]*$"
        },
        "notes": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } }
      },
      "additionalProperties": false
    },
    "grid": {
      "type": "object",
      "required": ["columns", "rows"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "column_sizing": { "enum": ["uniform", "content"] },
        "row_sizing": { "enum": ["uniform", "content"] },
        "min_col": { "type": "number", "exclusiveMinimum": 0 },
        "col_gap": { "type": "number", "minimum": 0 },
        "row_gap": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "lane": {
      "oneOf": [
        { "$ref": "#/$defs/guideLane" },
        { "$ref": "#/$defs/representationLane" }
      ]
    },
    "guideLane": {
      "type": "object",
      "required": ["id", "label", "position"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "position": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "representationLane": {
      "type": "object",
      "required": ["id", "label", "kind", "row", "representation_refs", "glyph"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "kind": { "const": "representation" },
        "row": { "type": "integer", "minimum": 1 },
        "representation_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/representationRef" }
        },
        "glyph": { "enum": ["single", "pair", "coordinates", "frames"] }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": ["id", "ref", "col", "row"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "ref": { "$ref": "#/$defs/nodeRef" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "notation": { "$ref": "#/$defs/notationString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "detail": { "$ref": "#/$defs/nonEmptyString" },
        "scale": { "$ref": "#/$defs/id" },
        "prominence": { "enum": ["primary", "secondary", "context"] },
        "treatment": { "enum": ["block", "compact", "chip"] },
        "density": { "enum": ["normal", "compact", "micro"] },
        "glyph": { "$ref": "#/$defs/representationGlyph" },
        "operator": { "$ref": "#/$defs/nonEmptyString" },
        "col": { "type": "integer", "minimum": 1 },
        "row": { "type": "integer", "minimum": 1 },
        "board_ref": { "$ref": "#/$defs/id" }
      },
      "additionalProperties": false
    },
    "region": {
      "type": "object",
      "required": ["id", "kind", "execution_ref", "label", "node_ids"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "const": "repeat" },
        "execution_ref": { "$ref": "#/$defs/executionLoopRef" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "iteration_relation_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/relationRef" }
        }
      },
      "additionalProperties": false
    },
    "pathMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": ["relation_ref"],
          "properties": { "relation_ref": { "$ref": "#/$defs/relationRef" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["relation_path"],
          "properties": {
            "relation_path": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/relationRef" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "occurrenceBinding": {
      "type": "object",
      "required": ["match", "from_occurrence", "to_occurrence"],
      "properties": {
        "match": { "$ref": "#/$defs/pathMatch" },
        "from_occurrence": { "$ref": "#/$defs/id" },
        "to_occurrence": { "$ref": "#/$defs/id" }
      },
      "additionalProperties": false
    },
    "elide": {
      "type": "object",
      "required": ["ref"],
      "properties": { "ref": { "$ref": "#/$defs/nodeRef" } },
      "additionalProperties": false
    },
    "exclude": {
      "type": "object",
      "required": ["ref", "reason"],
      "properties": {
        "ref": { "$ref": "#/$defs/nodeRef" },
        "reason": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "connection": {
      "type": "object",
      "required": ["title", "role", "inside"],
      "properties": {
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "inside": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "edgeOverride": {
      "type": "object",
      "required": ["match"],
      "properties": {
        "match": { "$ref": "#/$defs/pathMatch" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "notation": { "$ref": "#/$defs/notationString" },
        "tone": { "$ref": "#/$defs/id" },
        "connection": { "$ref": "#/$defs/connection" },
        "route_side": { "enum": ["top", "bottom", "left", "right"] },
        "route_clearance": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
